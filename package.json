{
  "name": "DevSecOpsTaskManager",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "start": "tsx src/index.ts",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/drizzle/migrate.ts",
    "migrate:docker": "docker-compose run --rm app pnpm migrate",
    "push": "drizzle-kit push",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=unit --config=jest.config.ts",
    "test:integration": "jest --testPathPatterns=integration --config=jest.config.ts --testTimeout=10000",
    "test:unit:ci": "jest --testPathPatterns=unit --config=jest.config.ts --ci --reporters=default --reporters=jest-junit",
    "test:integration:ci": "jest --testPathPatterns=integration --config=jest.config.ts --ci --reporters=default --reporters=jest-junit --maxWorkers=1 --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "Gideon Ngetich",
  "license": "ISC",
  "packageManager": "pnpm@10.8.0",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^7.0.12",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "jest": "^30.4.2",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.44.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "pg-pool": "^3.14.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^7.4.0",
    "zod": "^4.4.3"
  }
